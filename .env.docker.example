# ─── SM Unitur — variáveis do Docker Compose ─────────────────────────────────
# Copie este arquivo para .env (na RAIZ do projeto) e preencha os valores.
# O docker-compose lê o .env da raiz automaticamente para interpolação.
#
#   cp .env.docker.example .env
#
# ⚠️  NUNCA commite o .env com senhas reais. Ele já está no .gitignore.

# ── MySQL ─────────────────────────────────────────────────────────────────────
# Senha do root — usada apenas pelo healthcheck interno do container.
DB_ROOT_PASSWORD=rootpassword_TROQUE_AQUI

# Nome do banco, usuário e senha da aplicação
DB_NAME=smunitur
DB_USER=smunitur
DB_PASSWORD=smunitur123_TROQUE_AQUI

# ── JWT (autenticação do painel admin) ────────────────────────────────────────
# Mínimo 32 caracteres. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GERE_UM_SEGREDO_FORTE_AQUI_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10

# URL do frontend — usada pelo CORS do backend
FRONTEND_URL=http://localhost:3000

# ── Upload de imagens ─────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
MAX_IMAGE_DIM=2000

# ── Produção apenas ───────────────────────────────────────────────────────────
# Usado pelo docker-compose.prod.yml para embutir no build do Next.js
NEXT_PUBLIC_API_URL_PROD=https://SEU_DOMINIO.com.br/api
