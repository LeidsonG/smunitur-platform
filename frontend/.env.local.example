# Modelo de configuração do frontend — copie para .env.local e ajuste.
# Atenção: variáveis com prefixo `NEXT_PUBLIC_` são EMBUTIDAS no bundle
# enviado ao navegador. Nunca coloque segredos aqui.

# URL pública da API (deve incluir o sufixo /api).
# Dev local:
#   NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Produção (mesma origem, atrás do Nginx):
#   NEXT_PUBLIC_API_URL=https://smunitur.com.br/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api
