# Modelo de configuração — copie para .env e preencha.
# Em PRODUÇÃO, todos os valores marcados como OBRIGATÓRIO devem ser definidos
# com valores reais. O servidor aborta no boot se algum estiver faltando ou
# se o JWT_SECRET for muito curto / parecer com valor de exemplo.

# ─── Banco de dados ─────────────────────────────────────────────────────────
# OBRIGATÓRIO. Formato: mysql://usuario:senha@host:porta/banco
DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/smunitur"

# ─── JWT (autenticação do painel admin) ─────────────────────────────────────
# OBRIGATÓRIO. Mínimo 32 caracteres. Em produção, NUNCA use os valores de
# exemplo — o servidor recusa palavras como "troque", "secret", "example".
# Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# ─── Hash de senhas ─────────────────────────────────────────────────────────
# Default: 10 em dev, 12 em prod. Valores 10-15 são aceitos.
BCRYPT_ROUNDS=12

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS — URL do frontend ─────────────────────────────────────────────────
# OBRIGATÓRIO. Use o domínio real em produção (sem barra no final).
#   ex.: https://smunitur.com.br
FRONTEND_URL="https://SEU_DOMINIO_AQUI"

# ─── Upload de imagens ──────────────────────────────────────────────────────
# Limite em bytes. 10485760 = 10 MB. Mantenha alinhado com MAX_IMG no
# componente FormularioOrcamento do frontend.
MAX_FILE_SIZE=10485760
# Maior dimensão (px) após redimensionamento via sharp.
MAX_IMAGE_DIM=2000

# ─── Seed do admin inicial (opcional, mas RECOMENDADO em produção) ─────────
# Se omitir SEED_ADMIN_PASSWORD, será criada uma conta com senha "admin123"
# (apenas para desenvolvimento — nunca aceitável em produção).
SEED_ADMIN_EMAIL="admin@smunitur.com.br"
SEED_ADMIN_PASSWORD="DEFINA_UMA_SENHA_FORTE_AQUI"
