generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UsuarioAdmin {
  id        Int        @id @default(autoincrement())
  nome      String     @db.VarChar(100)
  email     String     @unique @db.VarChar(150)
  senha     String     @db.VarChar(255)
  nivel     NivelAdmin @default(operador)
  foto      String?    @db.VarChar(255)
  ativo     Boolean    @default(true)
  // Versão da sessão. Incrementada quando a senha muda ou quando o usuário
  // é desativado — invalida tokens JWT antigos sem precisar de blacklist
  // externa. O middleware compara `payload.tv` com este campo.
  tokenVersion Int     @default(0) @map("token_version")
  createdAt DateTime   @default(now()) @map("created_at")

  historicos OrcamentoStatusHistorico[]

  @@map("usuarios_admin")
}

enum NivelAdmin {
  super_admin
  admin
  operador
}

// ─── Linha de produtos ───────────────────────────────────────────────────────
// Agrupa modelos por tipo de peça (Camisetas, Moletons, Jalecos…).
// Terminologia da indústria de confecção: "linha" no lugar de "categoria".

model Linha {
  id      Int      @id @default(autoincrement())
  nome    String   @unique @db.VarChar(100)
  slug    String   @unique @db.VarChar(100)
  ativo   Boolean  @default(true)
  modelos Modelo[]

  @@map("linhas")
}

// ─── Modelo ──────────────────────────────────────────────────────────────────
// Variação específica dentro de uma linha (ex.: Camiseta Polo Premium,
// Camiseta Básica). É o que o cliente seleciona no formulário de orçamento.

model Modelo {
  id          Int      @id @default(autoincrement())
  linhaId     Int      @map("linha_id")
  nome        String   @db.VarChar(150)
  descricao   String?  @db.Text
  imagem      String?  @db.VarChar(255)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  linha           Linha                  @relation(fields: [linhaId], references: [id])
  especificacoes  ModeloEspecificacao[]

  @@unique([linhaId, nome])
  @@map("modelos")
}

// ─── Biblioteca global de Especificações ────────────────────────────────────
//
// Especificação = característica reutilizável (ex.: "Tipo de Gola", "Tecido").
// Variação      = valor possível dessa especificação (ex.: "Polo", "Careca").
// Ambas são "globais": cadastradas uma única vez em /admin/especificacoes e
// associadas a múltiplos modelos (ver ModeloEspecificacao).

model Especificacao {
  id    Int     @id @default(autoincrement())
  nome  String  @unique @db.VarChar(100)
  ordem Int     @default(0)
  // `ativo = false` esconde a especificação do formulário do cliente sem
  // perder o histórico de orçamentos que já a usaram.
  ativo Boolean @default(true)

  variacoes ModeloVariacao[]
  modelos   ModeloEspecificacao[]

  @@map("especificacoes")
}

model ModeloVariacao {
  id              Int     @id @default(autoincrement())
  especificacaoId Int     @map("especificacao_id")
  valor           String  @db.VarChar(100)
  imagem          String? @db.VarChar(255)
  ordem           Int     @default(0)

  especificacao        Especificacao                  @relation(fields: [especificacaoId], references: [id], onDelete: Cascade)
  modelosVariacoes     ModeloEspecificacaoVariacao[]
  // NOTA: SetNull em vez de Cascade. Se uma variação é excluída depois de já
  // ter sido usada em algum orçamento, o registro histórico permanece (apenas
  // a referência fica nula) — preserva a auditoria do que o cliente escolheu.
  // O `valorLivre` em OrcamentoEspecificacao pode ser usado como cópia textual.
  orcamentosEspecif    OrcamentoEspecificacao[]

  @@unique([especificacaoId, valor])
  @@map("variacoes")
}

// ─── Especificações por Modelo ───────────────────────────────────────────────

model ModeloEspecificacao {
  id              Int     @id @default(autoincrement())
  modeloId        Int     @map("modelo_id")
  especificacaoId Int     @map("especificacao_id")
  obrigatorio     Boolean @default(false)
  ordem           Int     @default(0)

  modelo            Modelo                         @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  especificacao     Especificacao                  @relation(fields: [especificacaoId], references: [id], onDelete: Cascade)
  variacoes         ModeloEspecificacaoVariacao[]
  orcamentosEspecif OrcamentoEspecificacao[]

  @@unique([modeloId, especificacaoId])
  @@map("modelo_especificacoes")
}

model ModeloEspecificacaoVariacao {
  id                    Int @id @default(autoincrement())
  modeloEspecificacaoId Int @map("modelo_especificacao_id")
  variacaoId            Int @map("variacao_id")

  modeloEspecificacao ModeloEspecificacao @relation(fields: [modeloEspecificacaoId], references: [id], onDelete: Cascade)
  variacao            ModeloVariacao      @relation(fields: [variacaoId], references: [id], onDelete: Cascade)

  @@unique([modeloEspecificacaoId, variacaoId])
  @@map("modelo_especificacao_variacoes")
}

// ─── Orçamentos ───────────────────────────────────────────────────────────────

model Orcamento {
  id               Int             @id @default(autoincrement())
  numero           Int             @unique
  nomeCliente      String          @map("nome_cliente") @db.VarChar(100)
  emailCliente     String          @map("email_cliente") @db.VarChar(150)
  telefoneCliente  String          @map("telefone_cliente") @db.VarChar(20)
  cpfCnpj          String?         @map("cpf_cnpj") @db.VarChar(20)
  modeloDesejado   String          @map("modelo_desejado") @db.VarChar(150)
  quantidade       Int             @db.UnsignedInt
  tamanhos         String?         @db.VarChar(255)
  cores            String?         @db.VarChar(255)
  detalhes         String?         @db.Text
  observacoes      String?         @db.Text
  imagemReferencia String?         @map("imagem_referencia") @db.VarChar(255)
  // Arte-final aprovada/em revisão pelo admin. Diferente da imagemReferencia
  // (que é o que o cliente enviou): aqui é o layout final que a equipe
  // produziu. Cliente vê no acompanhamento e admin compartilha por WhatsApp.
  layoutFinal      String?         @map("layout_final") @db.VarChar(255)
  valor            Decimal?        @db.Decimal(10, 2)
  status           StatusOrcamento @default(recebido)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  historicos             OrcamentoStatusHistorico[]
  especificacoesOrcament OrcamentoEspecificacao[]

  @@map("orcamentos")
}

enum StatusOrcamento {
  recebido
  em_analise
  aguardando_aprovacao
  em_producao
  finalizado
  enviado
  cancelado
}

model OrcamentoEspecificacao {
  id                    Int     @id @default(autoincrement())
  orcamentoId           Int     @map("orcamento_id")
  modeloEspecificacaoId Int?    @map("modelo_especificacao_id")
  variacaoId            Int?    @map("variacao_id")
  // Snapshot textual: copiado da Variação no momento da criação do orçamento.
  // Garante que o histórico continue legível mesmo se a variação original for
  // editada ou excluída no futuro.
  valorLivre            String? @map("valor_livre") @db.VarChar(255)

  orcamento           Orcamento            @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  // SetNull: mesmo motivo do `variacao` abaixo — preserva o histórico se um
  // modelo for despublicado/excluído.
  modeloEspecificacao ModeloEspecificacao? @relation(fields: [modeloEspecificacaoId], references: [id], onDelete: SetNull)
  variacao            ModeloVariacao?      @relation(fields: [variacaoId], references: [id], onDelete: SetNull)

  @@map("orcamento_especificacoes")
}

model OrcamentoStatusHistorico {
  id             Int      @id @default(autoincrement())
  orcamentoId    Int      @map("orcamento_id")
  statusAnterior String?  @map("status_anterior") @db.VarChar(50)
  statusNovo     String   @map("status_novo") @db.VarChar(50)
  observacao     String?  @db.Text
  usuarioId      Int?     @map("usuario_id")
  createdAt      DateTime @default(now()) @map("created_at")

  orcamento Orcamento     @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  usuario   UsuarioAdmin? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("orcamento_status_historico")
}
