generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UsuarioAdmin {
  id        Int        @id @default(autoincrement())
  nome      String     @db.VarChar(100)
  email     String     @unique @db.VarChar(150)
  senha     String     @db.VarChar(255)
  nivel     NivelAdmin @default(operador)
  foto      String?    @db.VarChar(255)
  ativo     Boolean    @default(true)
  // Versão da sessão. Incrementada quando a senha muda ou quando o usuário
  // é desativado — invalida tokens JWT antigos sem precisar de blacklist
  // externa. O middleware compara `payload.tv` com este campo.
  tokenVersion Int     @default(0) @map("token_version")
  createdAt DateTime   @default(now()) @map("created_at")

  historicos OrcamentoStatusHistorico[]

  @@map("usuarios_admin")
}

enum NivelAdmin {
  super_admin
  admin
  operador
}

model Categoria {
  id       Int       @id @default(autoincrement())
  nome     String    @unique @db.VarChar(100)
  slug     String    @unique @db.VarChar(100)
  ativo    Boolean   @default(true)
  produtos Produto[]

  @@map("categorias")
}

model Produto {
  id          Int      @id @default(autoincrement())
  categoriaId Int      @map("categoria_id")
  nome        String   @db.VarChar(150)
  descricao   String?  @db.Text
  imagem      String?  @db.VarChar(255)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  categoria Categoria        @relation(fields: [categoriaId], references: [id])
  atributos ProdutoAtributo[]

  @@unique([categoriaId, nome])
  @@map("produtos")
}

// ─── Biblioteca global de atributos ──────────────────────────────────────────
//
// Atributo  = característica reutilizável (ex.: "Tipo de Gola", "Tecido").
// Opção     = valor possível dessa característica (ex.: "Polo", "Careca").
// Ambas são "globais": cadastradas uma única vez em /admin/atributos e
// associadas a múltiplos produtos (ver ProdutoAtributo).

model Atributo {
  id    Int     @id @default(autoincrement())
  nome  String  @unique @db.VarChar(100)
  ordem Int     @default(0)
  // `ativo = false` esconde o atributo do formulário do cliente sem perder
  // o histórico de orçamentos que já o usaram.
  ativo Boolean @default(true)

  opcoes   OpcaoAtributo[]
  produtos ProdutoAtributo[]

  @@map("atributos")
}

model OpcaoAtributo {
  id         Int     @id @default(autoincrement())
  atributoId Int     @map("atributo_id")
  valor      String  @db.VarChar(100)
  imagem     String? @db.VarChar(255)
  ordem      Int     @default(0)

  atributo            Atributo               @relation(fields: [atributoId], references: [id], onDelete: Cascade)
  produtosOpcoes      ProdutoAtributoOpcao[]
  // NOTA: SetNull em vez de Cascade. Se uma opção é excluída depois de já ter
  // sido usada em algum orçamento, o registro histórico permanece (apenas a
  // referência fica nula) — preserva a auditoria do que o cliente escolheu.
  // O `valorLivre` em OrcamentoAtributo pode ser usado como cópia textual.
  orcamentosAtributos OrcamentoAtributo[]

  @@unique([atributoId, valor])
  @@map("opcoes_atributo")
}

// ─── Atributos por produto ────────────────────────────────────────────────────

model ProdutoAtributo {
  id          Int     @id @default(autoincrement())
  produtoId   Int     @map("produto_id")
  atributoId  Int     @map("atributo_id")
  obrigatorio Boolean @default(false)
  ordem       Int     @default(0)

  produto             Produto                @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  atributo            Atributo               @relation(fields: [atributoId], references: [id], onDelete: Cascade)
  opcoes              ProdutoAtributoOpcao[]
  orcamentosAtributos OrcamentoAtributo[]

  @@unique([produtoId, atributoId])
  @@map("produto_atributos")
}

model ProdutoAtributoOpcao {
  id                Int @id @default(autoincrement())
  produtoAtributoId Int @map("produto_atributo_id")
  opcaoId           Int @map("opcao_id")

  produtoAtributo ProdutoAtributo @relation(fields: [produtoAtributoId], references: [id], onDelete: Cascade)
  opcao           OpcaoAtributo   @relation(fields: [opcaoId], references: [id], onDelete: Cascade)

  @@unique([produtoAtributoId, opcaoId])
  @@map("produto_atributo_opcoes")
}

// ─── Orçamentos ───────────────────────────────────────────────────────────────

model Orcamento {
  id               Int             @id @default(autoincrement())
  numero           Int             @unique
  nomeCliente      String          @map("nome_cliente") @db.VarChar(100)
  emailCliente     String          @map("email_cliente") @db.VarChar(150)
  telefoneCliente  String          @map("telefone_cliente") @db.VarChar(20)
  cpfCnpj          String?         @map("cpf_cnpj") @db.VarChar(20)
  produtoDesejado  String          @map("produto_desejado") @db.VarChar(150)
  quantidade       Int             @db.UnsignedInt
  tamanhos         String?         @db.VarChar(255)
  cores            String?         @db.VarChar(255)
  detalhes         String?         @db.Text
  observacoes      String?         @db.Text
  imagemReferencia String?         @map("imagem_referencia") @db.VarChar(255)
  // Arte-final aprovada/em revisão pelo admin. Diferente da imagemReferencia
  // (que é o que o cliente enviou): aqui é o layout final que a equipe
  // produziu. Cliente vê no acompanhamento e admin compartilha por WhatsApp.
  layoutFinal      String?         @map("layout_final") @db.VarChar(255)
  valor            Decimal?        @db.Decimal(10, 2)
  status           StatusOrcamento @default(recebido)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  historicos         OrcamentoStatusHistorico[]
  atributosOrcamento OrcamentoAtributo[]

  @@map("orcamentos")
}

enum StatusOrcamento {
  recebido
  em_analise
  aguardando_aprovacao
  em_producao
  finalizado
  enviado
  cancelado
}

model OrcamentoAtributo {
  id                Int     @id @default(autoincrement())
  orcamentoId       Int     @map("orcamento_id")
  produtoAtributoId Int?    @map("produto_atributo_id")
  opcaoId           Int?    @map("opcao_id")
  // Snapshot textual: copiado da Opção no momento da criação do orçamento.
  // Garante que o histórico continue legível mesmo se a opção original for
  // editada ou excluída no futuro.
  valorLivre        String? @map("valor_livre") @db.VarChar(255)

  orcamento       Orcamento       @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  // SetNull em produtoAtributo: mesmo motivo do `opcao` abaixo — preserva
  // o histórico se um produto for despublicado/excluído.
  produtoAtributo ProdutoAtributo? @relation(fields: [produtoAtributoId], references: [id], onDelete: SetNull)
  opcao           OpcaoAtributo?  @relation(fields: [opcaoId], references: [id], onDelete: SetNull)

  @@map("orcamento_atributos")
}

model OrcamentoStatusHistorico {
  id             Int      @id @default(autoincrement())
  orcamentoId    Int      @map("orcamento_id")
  statusAnterior String?  @map("status_anterior") @db.VarChar(50)
  statusNovo     String   @map("status_novo") @db.VarChar(50)
  observacao     String?  @db.Text
  usuarioId      Int?     @map("usuario_id")
  createdAt      DateTime @default(now()) @map("created_at")

  orcamento Orcamento     @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  usuario   UsuarioAdmin? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("orcamento_status_historico")
}
